# SFTP Credential Store
# Copy this file to credentials.yml and populate with encrypted values.
#
# NEVER commit credentials.yml to version control.
#
# Fields:
#   ref   — unique credential reference (used by job definitions)
#   type  — PASSWORD or SSH_KEY
#   value — encrypted secret (generated via: sftp-credential.sh add <ref> <type> <value>)
#
# Encryption: AES-256-GCM, keyed by ORCHESTRATOR_ENCRYPTION_KEY env var.

credentials: []
